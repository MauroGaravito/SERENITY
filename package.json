{
  "name": "serenity",
  "version": "2.0.0",
  "private": true,
  "engines": {
    "node": ">=22.15.0",
    "npm": ">=11.10.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "next typegen && tsc --noEmit -p tsconfig.check.json",
    "db:start": "docker compose up -d postgres",
    "db:stop": "docker compose down",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.mjs",
    "db:seed:colombia": "node prisma/seed.mjs --profile=colombia",
    "db:seed:australia": "node prisma/seed.mjs --profile=australia"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  },
  "dependencies": {
    "@prisma/client": "^6.7.0",
    "next": "^15.5.15",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "eslint": "^9.25.0",
    "eslint-config-next": "^15.5.15",
    "prisma": "^6.7.0",
    "typescript": "^5.8.3"
  },
  "overrides": {
    "effect": "3.20.0",
    "defu": "6.1.7"
  }
}
