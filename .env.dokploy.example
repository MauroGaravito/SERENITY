# Serenity - Dokploy deployment environment
# Current architecture: single Next.js application + PostgreSQL

NODE_ENV="production"
PORT="3000"

# Replace the host with your Dokploy/PostgreSQL service name or internal hostname.
DATABASE_URL="postgresql://postgres:CHANGE_ME_DB_PASSWORD@serenity-postgres:5432/serenity?schema=public"

# Generate a long random secret for signed session cookies.
AUTH_SECRET="CHANGE_ME_WITH_A_LONG_RANDOM_SECRET"

# Keep public login pages free of shared demo credentials.
SHOW_DEMO_CREDENTIALS="false"

# Reserved for future absolute URL / emails / webhooks.
APP_URL="https://aged-care.downundersolutions.com"
